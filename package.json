{
  "private": true,
  "scripts": {
    "build": "pnpm --filter './packages/*' --if-present build",
    "dev": "pnpm --filter './packages/*' --parallel --if-present dev",
    "lint": "oxlint packages",
    "lint:fix": "oxlint --fix packages",
    "test": "pnpm --filter './packages/*' --if-present test",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "clean": "pnpm -r exec rm -rf dist && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "oxlint packages && pnpm --filter './packages/*' --if-present build && pnpm --filter './packages/*' --if-present test && changeset version && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.4.8",
    "@changesets/cli": "^2.22.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.3"
    }
  },
  "packageManager": "pnpm@9.4.0"
}
