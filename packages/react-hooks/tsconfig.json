{
  "extends": "@edram/tsconfig",
  "compilerOptions": {
    "rootDir": "./",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noUncheckedIndexedAccess": true,
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "./src/**/*",
    "./tests/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
