{
  "name": "@edram/react-hooks",
  "version": "0.0.20",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@edram/react-utils": "workspace:^",
    "@types/ua-parser-js": "^0.7.39",
    "copy-to-clipboard": "^3.3.3",
    "ua-parser-js": "^1.0.37"
  },
  "devDependencies": {
    "@edram/tsconfig": "workspace:^",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/node": "^22.12.0",
    "@types/react": "^17.0.0",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "jsdom": "^22.1.0",
    "oxlint": "^1.68.0",
    "oxlint-config-edram": "workspace:^",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "tsdown": "^0.22.2",
    "typescript": "^5.2.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "react": "^16.8.0  || ^17.0.0 || ^18.0.0",
    "react-dom": "^16.8.0  || ^17.0.0 || ^18.0.0"
  }
}
