{
  "name": "@edram/react-utils",
  "version": "0.1.0",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@edram/utils": "workspace:^"
  },
  "devDependencies": {
    "@edram/tsconfig": "workspace:^",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.2.27",
    "jsdom": "^22.1.0",
    "oxlint": "^1.68.0",
    "oxlint-config-edram": "workspace:^",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsdown": "^0.22.2",
    "typescript": "^5.2.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "react": "^16.8.0  || ^17.0.0 || ^18.0.0",
    "react-dom": "^16.8.0  || ^17.0.0 || ^18.0.0"
  }
}
