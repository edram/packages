{
  "name": "@edram/utils",
  "version": "0.1.0",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint src",
    "test": "vitest run"
  },
  "devDependencies": {
    "@edram/tsconfig": "workspace:^",
    "jsdom": "^22.1.0",
    "oxlint": "^1.68.0",
    "oxlint-config-edram": "workspace:^",
    "tsdown": "^0.22.2",
    "typescript": "^5.2.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
