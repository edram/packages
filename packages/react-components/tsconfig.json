{
  "extends": "@edram/tsconfig",
  "compilerOptions": {
    "rootDir": "./",
    "jsx": "react",
    "types": [
      "vitest/globals",
      "react"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": [
    "./src/**/*",
    "./test/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
